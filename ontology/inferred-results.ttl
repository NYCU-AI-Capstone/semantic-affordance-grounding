@prefix cap: <https://hcis.io/ontology/aicapstone/2026/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix g04: <https://hcis.io/ontology/aicapstone/2026/group04/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cap:canBeManipulatedBy a owl:ObjectProperty ;
    rdfs:label "can be manipulated by"@en ;
    rdfs:comment "Relates a physical object to an end effector capable of manipulating it."@en ;
    rdfs:domain cap:PhysicalObject ;
    rdfs:range cap:EndEffector .

cap:group04 a owl:Ontology ;
    rdfs:label "AI Capstone 2026 Group 04 Ontology"@en ;
    dcterms:created "2026-05-26"^^xsd:date ;
    dcterms:creator g04:group04team ;
    dcterms:description "This ontology extends the shared course vocabulary (cap:) with Group 04 specific individuals, the GraspableObject inference class, and an advanced shell-game task in which a ball is concealed under one of several cups; the cup that conceals the ball is inferred (g04:BallConcealingCup) as the robot's retrieval target. It demonstrates a complete semantic grounding loop from perceived objects to inferred graspability and inferred task targets."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "AI Capstone 2026 Group 04 Ontology"@en ;
    vann:preferredNamespacePrefix "g04" ;
    vann:preferredNamespaceUri "https://hcis.io/ontology/aicapstone/2026/group04/" ;
    rdfs:comment "Group 04 ontology for Homework 5: Ontology-based Semantic Grounding. This ontology defines group-specific object instances, affordance individuals, task individuals, and the GraspableObject reasoning pattern for the three baseline tasks (cup stacking, cutlery arrangement, toy block collection) plus an advanced shell-game (ball-under-cup) task with concealment-based target inference."@en ;
    owl:imports <https://hcis.io/ontology/aicapstone/2026> .

g04:blockCollectionTask a cap:ManipulationTask,
        cap:Task ;
    rdfs:label "toy block collection task"@en ;
    rdfs:comment "A manipulation task in which the robot collects toy blocks into a basket."@en ;
    cap:hasReferenceObject g04:basket01 ;
    cap:hasTargetObject g04:block01 .

g04:concealedBy a owl:ObjectProperty ;
    rdfs:label "concealed by"@en ;
    rdfs:comment "Inverse of g04:conceals: relates a ball to the cup that hides it."@en ;
    rdfs:domain g04:Ball ;
    rdfs:range cap:Cup ;
    owl:inverseOf g04:conceals .

g04:cupStackingTask a cap:ManipulationTask,
        cap:Task ;
    rdfs:label "cup stacking task"@en ;
    rdfs:comment "A manipulation task in which the robot stacks cups by grasping and placing them."@en ;
    cap:hasTargetObject g04:blueCup01,
        g04:pinkCup01 .

g04:cutleryArrangementTask a cap:ManipulationTask,
        cap:Task ;
    rdfs:label "cutlery arrangement task"@en ;
    rdfs:comment "A manipulation task in which the robot arranges cutlery relative to a plate."@en ;
    cap:hasReferenceObject g04:plate01 ;
    cap:hasTargetObject g04:fork01,
        g04:knife01 .

g04:isOpaque a owl:DatatypeProperty ;
    rdfs:label "is opaque"@en ;
    rdfs:comment "Records whether a physical object is visually opaque (cannot be seen through). Orthogonal to cap:hasColor (which records colour only). In the shell-game task opacity is the perceptual property that makes concealment possible: because the cups are opaque, the robot cannot see which one hides the ball and must infer the retrieval target by reasoning rather than direct observation."@en ;
    rdfs:domain cap:PhysicalObject ;
    rdfs:range xsd:boolean .

g04:robotAgent01 a cap:RobotAgent ;
    rdfs:label "robot agent 01"@en ;
    rdfs:comment "The robot agent used by Group 04 in the task environment. It perceives objects, reasons over the ontology, and acts through its end effector."@en .

g04:shellGameTask a cap:ManipulationTask,
        cap:Task ;
    rdfs:label "shell game task"@en ;
    rdfs:comment "A manipulation task in which a ball is hidden under one of several shuffled, identical cups and the robot must grasp the cup that conceals the ball. The retrieval target is the inferred g04:BallConcealingCup."@en ;
    cap:hasReferenceObject g04:ball01 ;
    cap:hasTargetObject g04:shellCup01,
        g04:shellCup02,
        g04:shellCup03 .

cap:hasApproxWidth a owl:DatatypeProperty ;
    rdfs:label "has approximate width"@en ;
    rdfs:comment "Records an approximate object width, which may be useful for checking whether an object fits within a gripper capability."@en ;
    rdfs:domain cap:PhysicalObject ;
    rdfs:range xsd:decimal .

cap:hasColor a owl:DatatypeProperty ;
    rdfs:label "has color"@en ;
    rdfs:comment "Records the perceived or assigned color of a physical object."@en ;
    rdfs:domain cap:PhysicalObject ;
    rdfs:range xsd:string .

cap:hasObjectLabel a owl:DatatypeProperty ;
    rdfs:label "has object label"@en ;
    rdfs:comment "Records the object label used by perception, simulation, or task documentation."@en ;
    rdfs:domain cap:PhysicalObject ;
    rdfs:range xsd:string .

cap:hasPoseFrame a owl:DatatypeProperty ;
    rdfs:label "has pose frame"@en ;
    rdfs:comment "Links an ontology individual to a coordinate frame or pose-frame identifier used in perception, reconstruction, or simulation."@en ;
    rdfs:domain cap:PhysicalObject ;
    rdfs:range xsd:string .

cap:hasReferenceObject a owl:ObjectProperty ;
    rdfs:label "has reference object"@en ;
    rdfs:comment "Relates a task to a physical object used as a spatial or semantic reference."@en ;
    rdfs:domain cap:Task ;
    rdfs:range cap:PhysicalObject .

cap:hasTargetObject a owl:ObjectProperty ;
    rdfs:label "has target object"@en ;
    rdfs:comment "Relates a task to a physical object that is directly acted upon in that task."@en ;
    rdfs:domain cap:Task ;
    rdfs:range cap:PhysicalObject .

cap:hasTaskRole a owl:ObjectProperty ;
    rdfs:label "has task role"@en ;
    rdfs:comment "Relates a physical object to the role it plays in a task."@en ;
    rdfs:domain cap:PhysicalObject ;
    rdfs:range cap:TaskRole .

<https://hcis.io/ontology/aicapstone/2026> a owl:Ontology ;
    rdfs:label "AI Capstone 2026 Course Ontology"@en ;
    dcterms:created "2026-05-22"^^xsd:date ;
    dcterms:creator cap:ccyont ;
    dcterms:description "This ontology defines a compact course vocabulary for representing physical task objects, task roles, manipulation affordances, grounding identifiers, and inferable graspability in the AI Capstone 2026 Physical AI project."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "AI Capstone 2026 Course Ontology"@en ;
    vann:preferredNamespacePrefix "cap" ;
    vann:preferredNamespaceUri "https://hcis.io/ontology/aicapstone/2026/" ;
    rdfs:comment "A reduced educational ontology profile for semantic and affordance grounding of graspable objects in the AI Capstone 2026 course project."@en .

cap:Basket a owl:Class ;
    rdfs:label "basket"@en ;
    rdfs:comment "A container target used to receive toy blocks in the toy-block-collection task."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cap:hasAffordance ;
            owl:someValuesFrom cap:ContainmentAffordance ],
        cap:PhysicalObject .

cap:CollectableObject a owl:Class ;
    rdfs:label "collectable object"@en ;
    rdfs:comment "A task role for an object that should be collected into another object or location."@en ;
    rdfs:subClassOf cap:TaskRole .

cap:ContainerTarget a owl:Class ;
    rdfs:label "container target"@en ;
    rdfs:comment "A task role for an object that receives or contains other objects."@en ;
    rdfs:subClassOf cap:TaskRole .

cap:Fork a owl:Class ;
    rdfs:label "fork"@en ;
    rdfs:comment "A cutlery object to be placed in the cutlery-arrangement task."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cap:hasAffordance ;
            owl:someValuesFrom cap:GraspingAffordance ],
        cap:PhysicalObject .

cap:Knife a owl:Class ;
    rdfs:label "knife"@en ;
    rdfs:comment "A cutlery object to be placed in the cutlery-arrangement task."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cap:hasAffordance ;
            owl:someValuesFrom cap:GraspingAffordance ],
        cap:PhysicalObject .

cap:Plate a owl:Class ;
    rdfs:label "plate"@en ;
    rdfs:comment "A reference object used for arranging cutlery in the cutlery-arrangement task."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cap:hasAffordance ;
            owl:someValuesFrom cap:SupportAffordance ],
        cap:PhysicalObject .

cap:ReferenceObject a owl:Class ;
    rdfs:label "reference object"@en ;
    rdfs:comment "A task role for an object used as a spatial or semantic reference for arranging other objects."@en ;
    rdfs:subClassOf cap:TaskRole .

cap:RobotAgent a owl:Class ;
    rdfs:label "robot agent"@en ;
    rdfs:comment "A robot or robot-controlled agent that can perceive objects, reason over the ontology, and act in the task environment."@en .

cap:ToyBlock a owl:Class ;
    rdfs:label "toy block"@en ;
    rdfs:comment "A small object to be collected into the basket in the toy-block-collection task."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cap:hasAffordance ;
            owl:someValuesFrom cap:GraspingAffordance ],
        cap:PhysicalObject .

cap:ccyont a foaf:Person ;
    foaf:mbox <mailto:ccy@hptp.org> ;
    foaf:name "Chun-yien Chang"@en .

g04:BallConcealingCup a owl:Class ;
    rdfs:label "ball-concealing cup"@en ;
    rdfs:comment "A cup inferred to conceal the target ball, and therefore the robot's retrieval (grasp) target in the shell-game task. Defined as the intersection of cap:Cup and the existential restriction that the cup conceals at least one g04:Ball. Membership is derived by the reasoner from g04:conceals assertions, not asserted directly."@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( cap:Cup [ a owl:Restriction ;
                        owl:onProperty g04:conceals ;
                        owl:someValuesFrom g04:Ball ] ) ] .

g04:HiddenItem a owl:Class ;
    rdfs:label "hidden item"@en ;
    rdfs:comment "The role of the object that is concealed under a cup and must be located by the robot through the concealing cup."@en ;
    rdfs:subClassOf cap:TaskRole .

g04:basket01 a cap:Basket,
        cap:PhysicalObject ;
    rdfs:label "basket 01"@en ;
    rdfs:comment "The basket instance defined by Group 04 for the baseline toy-block-collection task. Serves as the container target for collecting toy blocks; not directly grasped."@en ;
    cap:hasAffordance [ a cap:Affordance,
                cap:ContainmentAffordance ] ;
    cap:hasColor "brown" ;
    cap:hasObjectLabel "basket" ;
    cap:hasPoseFrame "world/object_basket" ;
    cap:hasTaskRole cap:ContainerTarget .

g04:block01 a cap:GraspableObject,
        cap:PhysicalObject,
        cap:ToyBlock ;
    rdfs:label "toy block 01"@en ;
    rdfs:comment "The toy block instance defined by Group 04 for the baseline toy-block-collection task."@en ;
    cap:canBeManipulatedBy g04:gripper01 ;
    cap:hasAffordance [ a cap:Affordance,
                cap:GraspingAffordance ] ;
    cap:hasColor "red" ;
    cap:hasObjectLabel "toy_block" ;
    cap:hasPoseFrame "world/object_block" ;
    cap:hasTaskRole cap:CollectableObject .

g04:blueCup01 a cap:Cup,
        cap:GraspableObject,
        cap:PhysicalObject ;
    rdfs:label "blue cup 01"@en ;
    rdfs:comment "The blue cup instance defined by Group 04 for the baseline cup-stacking task."@en ;
    cap:canBeManipulatedBy g04:gripper01 ;
    cap:hasAffordance [ a cap:Affordance,
                cap:GraspingAffordance ],
        [ a cap:Affordance,
                cap:StackabilityAffordance ] ;
    cap:hasColor "blue" ;
    cap:hasObjectLabel "blue_cup" ;
    cap:hasPoseFrame "world/object_blue_cup" ;
    cap:hasTaskRole cap:TargetObject .

g04:fork01 a cap:Fork,
        cap:GraspableObject,
        cap:PhysicalObject ;
    rdfs:label "fork 01"@en ;
    rdfs:comment "The fork instance defined by Group 04 for the baseline cutlery-arrangement task."@en ;
    cap:canBeManipulatedBy g04:gripper01 ;
    cap:hasAffordance [ a cap:Affordance,
                cap:GraspingAffordance ] ;
    cap:hasColor "silver" ;
    cap:hasObjectLabel "fork" ;
    cap:hasPoseFrame "world/object_fork" ;
    cap:hasTaskRole cap:TargetObject .

g04:group04team a foaf:Group ;
    foaf:name "Group 04"@en .

g04:knife01 a cap:GraspableObject,
        cap:Knife,
        cap:PhysicalObject ;
    rdfs:label "knife 01"@en ;
    rdfs:comment "The knife instance defined by Group 04 for the baseline cutlery-arrangement task."@en ;
    cap:canBeManipulatedBy g04:gripper01 ;
    cap:hasAffordance [ a cap:Affordance,
                cap:GraspingAffordance ] ;
    cap:hasColor "silver" ;
    cap:hasObjectLabel "knife" ;
    cap:hasPoseFrame "world/object_knife" ;
    cap:hasTaskRole cap:TargetObject .

g04:pinkCup01 a cap:Cup,
        cap:GraspableObject,
        cap:PhysicalObject ;
    rdfs:label "pink cup 01"@en ;
    rdfs:comment "The pink cup instance defined by Group 04 for the baseline cup-stacking task."@en ;
    cap:canBeManipulatedBy g04:gripper01 ;
    cap:hasAffordance [ a cap:Affordance,
                cap:StackabilityAffordance ],
        [ a cap:Affordance,
                cap:GraspingAffordance ] ;
    cap:hasColor "pink" ;
    cap:hasObjectLabel "pink_cup" ;
    cap:hasPoseFrame "world/object_pink_cup" ;
    cap:hasTaskRole cap:TargetObject .

g04:plate01 a cap:PhysicalObject,
        cap:Plate ;
    rdfs:label "plate 01"@en ;
    rdfs:comment "The plate instance defined by Group 04 for the baseline cutlery-arrangement task. Serves as a reference object for placing cutlery; not directly grasped."@en ;
    cap:hasAffordance [ a cap:Affordance,
                cap:SupportAffordance ] ;
    cap:hasColor "white" ;
    cap:hasObjectLabel "plate" ;
    cap:hasPoseFrame "world/object_plate" ;
    cap:hasTaskRole cap:ReferenceObject .

g04:shellCup01 a cap:Cup,
        cap:GraspableObject,
        cap:PhysicalObject ;
    rdfs:label "shell cup 01"@en ;
    rdfs:comment "Shell-game cup 01: one of several identical opaque cups that may conceal the ball. Empty in the current post-shuffle state."@en ;
    cap:canBeManipulatedBy g04:gripper01 ;
    g04:isOpaque true ;
    cap:hasAffordance [ a cap:Affordance,
                cap:StackabilityAffordance ],
        [ a cap:Affordance,
                cap:GraspingAffordance ],
        [ a cap:Affordance,
                cap:ContainmentAffordance,
                g04:ConcealmentAffordance ] ;
    cap:hasColor "pink" ;
    cap:hasObjectLabel "shell_cup" ;
    cap:hasPoseFrame "world/object_cup01" ;
    cap:hasTaskRole g04:CandidateContainer .

g04:shellCup02 a cap:Cup,
        cap:GraspableObject,
        cap:PhysicalObject,
        g04:BallConcealingCup ;
    rdfs:label "shell cup 02"@en ;
    rdfs:comment "Shell-game cup 02: identical to the other cups, but conceals the ball in the current post-shuffle state. The reasoner infers it as g04:BallConcealingCup (the retrieval target)."@en ;
    cap:canBeManipulatedBy g04:gripper01 ;
    g04:conceals g04:ball01 ;
    g04:isOpaque true ;
    cap:hasAffordance [ a cap:Affordance,
                cap:GraspingAffordance ],
        [ a cap:Affordance,
                cap:StackabilityAffordance ],
        [ a cap:Affordance,
                cap:ContainmentAffordance,
                g04:ConcealmentAffordance ] ;
    cap:hasColor "pink" ;
    cap:hasObjectLabel "shell_cup" ;
    cap:hasPoseFrame "world/object_cup02" ;
    cap:hasTaskRole g04:CandidateContainer .

g04:shellCup03 a cap:Cup,
        cap:GraspableObject,
        cap:PhysicalObject ;
    rdfs:label "shell cup 03"@en ;
    rdfs:comment "Shell-game cup 03: one of several identical opaque cups that may conceal the ball. Empty in the current post-shuffle state."@en ;
    cap:canBeManipulatedBy g04:gripper01 ;
    g04:isOpaque true ;
    cap:hasAffordance [ a cap:Affordance,
                cap:GraspingAffordance ],
        [ a cap:Affordance,
                cap:StackabilityAffordance ],
        [ a cap:Affordance,
                cap:ContainmentAffordance,
                g04:ConcealmentAffordance ] ;
    cap:hasColor "pink" ;
    cap:hasObjectLabel "shell_cup" ;
    cap:hasPoseFrame "world/object_cup03" ;
    cap:hasTaskRole g04:CandidateContainer .

cap:EndEffector a owl:Class ;
    rdfs:label "end effector"@en ;
    rdfs:comment "A robot component used to physically interact with objects, such as a gripper."@en .

cap:SupportAffordance a owl:Class ;
    rdfs:label "support affordance"@en ;
    rdfs:comment "An affordance by which an object can support the placement or arrangement of other objects."@en ;
    rdfs:subClassOf cap:Affordance .

g04:ball01 a cap:PhysicalObject,
        g04:Ball ;
    rdfs:label "ball 01"@en ;
    rdfs:comment "The small ball hidden under one of the shell-game cups in the current post-shuffle state."@en ;
    cap:hasColor "white" ;
    cap:hasObjectLabel "ball" ;
    cap:hasPoseFrame "world/object_ball" ;
    cap:hasTaskRole g04:HiddenItem .

g04:conceals a owl:ObjectProperty ;
    rdfs:label "conceals"@en ;
    rdfs:comment "Relates a cup to a ball that is hidden under (concealed by) that cup in the post-shuffle state. This is a perception/tracking-grounded fact asserted by the robot, from which the retrieval target is inferred."@en ;
    rdfs:domain cap:Cup ;
    rdfs:range g04:Ball .

g04:CandidateContainer a owl:Class ;
    rdfs:label "candidate container"@en ;
    rdfs:comment "The role of a cup that may conceal the target ball before reasoning identifies the actual concealing cup. Asserted on every shell-game cup so that no single cup is pre-labelled as the answer."@en ;
    rdfs:subClassOf cap:TaskRole .

g04:ConcealmentAffordance a owl:Class ;
    rdfs:label "concealment affordance"@en ;
    rdfs:comment "An affordance by which an inverted, opaque cup can hide (conceal) a small object placed under it. A specialization of cap:ContainmentAffordance scoped to the shell-game occlusion semantics."@en ;
    rdfs:subClassOf cap:ContainmentAffordance .

cap:ManipulationTask a owl:Class ;
    rdfs:label "manipulation task"@en ;
    rdfs:comment "A task in which a robot changes the pose, state, or arrangement of physical objects."@en ;
    rdfs:subClassOf cap:Task .

cap:TargetObject a owl:Class ;
    rdfs:label "target object"@en ;
    rdfs:comment "A task role for an object that is directly acted upon or manipulated."@en ;
    rdfs:subClassOf cap:TaskRole .

g04:Ball a owl:Class ;
    rdfs:label "ball"@en ;
    rdfs:comment "A small ball used in the shell-game task. It is the item hidden under a cup. In Group 04's model the ball is not a direct grasp target (no grasping affordance); the robot retrieves it indirectly by grasping the concealing cup."@en ;
    rdfs:subClassOf cap:PhysicalObject .

cap:ContainmentAffordance a owl:Class ;
    rdfs:label "containment affordance"@en ;
    rdfs:comment "An affordance by which an object can contain or receive other objects."@en ;
    rdfs:subClassOf cap:Affordance .

cap:StackabilityAffordance a owl:Class ;
    rdfs:label "stackability affordance"@en ;
    rdfs:comment "An affordance by which an object can participate in a stacking relation with another object."@en ;
    rdfs:subClassOf cap:Affordance .

cap:Task a owl:Class ;
    rdfs:label "task"@en ;
    rdfs:comment "A goal-directed activity to be performed or evaluated in the course project."@en .

cap:TaskRole a owl:Class ;
    rdfs:label "task role"@en ;
    rdfs:comment "A role that an object plays within a task."@en .

cap:Cup a owl:Class ;
    rdfs:label "cup"@en ;
    rdfs:comment "A container-like object used in the cup-stacking task."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty cap:hasAffordance ;
            owl:someValuesFrom cap:GraspingAffordance ],
        [ a owl:Restriction ;
            owl:onProperty cap:hasAffordance ;
            owl:someValuesFrom cap:StackabilityAffordance ],
        cap:PhysicalObject .

cap:GraspableObject a owl:Class ;
    rdfs:label "graspable object"@en ;
    rdfs:comment "A physical object inferred to afford grasping by a robot end effector in the task context. Defined as the intersection of cap:PhysicalObject and the existential restriction that the object has at least one cap:hasAffordance relation to a cap:GraspingAffordance individual."@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( cap:PhysicalObject [ a owl:Restriction ;
                        owl:onProperty cap:hasAffordance ;
                        owl:someValuesFrom cap:GraspingAffordance ] ) ] .

g04:gripper01 a cap:EndEffector ;
    rdfs:label "parallel gripper 01"@en ;
    rdfs:comment "The parallel-jaw gripper attached to the robot agent, used for grasping and manipulating physical objects."@en .

cap:hasAffordance a owl:ObjectProperty ;
    rdfs:label "has affordance"@en ;
    rdfs:comment "Relates a physical object to an affordance associated with that object in the task context."@en ;
    rdfs:domain cap:PhysicalObject ;
    rdfs:range cap:Affordance .

cap:GraspingAffordance a owl:Class ;
    rdfs:label "grasping affordance"@en ;
    rdfs:comment "An affordance by which an object may be grasped, held, lifted, or repositioned by a robot gripper."@en ;
    rdfs:subClassOf cap:Affordance .

cap:Affordance a owl:Class ;
    rdfs:label "affordance"@en ;
    rdfs:comment "An action possibility associated with an object in relation to a robot capability and task context."@en .

cap:PhysicalObject a owl:Class ;
    rdfs:label "physical object"@en ;
    rdfs:comment "A material object in the task environment that may be perceived, manipulated, used as a reference object, or assigned a task role."@en .

