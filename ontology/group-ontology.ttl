@prefix cap:     <https://hcis.io/ontology/aicapstone/2026/> .
@prefix g04:     <https://hcis.io/ontology/aicapstone/2026/group04/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann:    <http://purl.org/vocab/vann/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .

# =============================================================================
# Ontology Metadata (PDF §8)
# =============================================================================

<https://hcis.io/ontology/aicapstone/2026/group04>
    a owl:Ontology ;
    owl:imports <https://hcis.io/ontology/aicapstone/2026> ;
    rdfs:label "AI Capstone 2026 Group 04 Ontology"@en ;
    rdfs:comment
        "Group 04 ontology for Homework 5: Ontology-based Semantic Grounding. This ontology defines group-specific object instances, affordance individuals, task individuals, and the GraspableObject reasoning pattern for the three baseline tasks (cup stacking, cutlery arrangement, toy block collection) plus an advanced shell-game (ball-under-cup) task with concealment-based target inference."@en ;
    dcterms:title "AI Capstone 2026 Group 04 Ontology"@en ;
    dcterms:description
        "This ontology extends the shared course vocabulary (cap:) with Group 04 specific individuals, the GraspableObject inference class, and an advanced shell-game task in which a ball is concealed under one of several cups; the cup that conceals the ball is inferred (g04:BallConcealingCup) as the robot's retrieval target. It demonstrates a complete semantic grounding loop from perceived objects to inferred graspability and inferred task targets."@en ;
    dcterms:creator g04:group04team ;
    dcterms:created "2026-05-26"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    vann:preferredNamespacePrefix "g04" ;
    vann:preferredNamespaceUri "https://hcis.io/ontology/aicapstone/2026/group04/" .

g04:group04team
    a foaf:Group ;
    foaf:name "Group 04"@en .

# =============================================================================
# GraspableObject Reasoning Pattern (PDF §11 Listing 5)
# =============================================================================
# Description Logic: cap:GraspableObject ≡ cap:PhysicalObject ⊓ ∃cap:hasAffordance.cap:GraspingAffordance
# This class is NOT in the official course-affordance.ttl; each group defines it.

cap:GraspableObject
    a owl:Class ;
    rdfs:label "graspable object"@en ;
    rdfs:comment
        "A physical object inferred to afford grasping by a robot end effector in the task context. Defined as the intersection of cap:PhysicalObject and the existential restriction that the object has at least one cap:hasAffordance relation to a cap:GraspingAffordance individual."@en ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            cap:PhysicalObject
            [ a owl:Restriction ;
              owl:onProperty cap:hasAffordance ;
              owl:someValuesFrom cap:GraspingAffordance ]
        )
    ] .

# =============================================================================
# Robot Agent and End Effector (PDF §4)
# =============================================================================

g04:robotAgent01
    a cap:RobotAgent ;
    rdfs:label "robot agent 01"@en ;
    rdfs:comment
        "The robot agent used by Group 04 in the task environment. It perceives objects, reasons over the ontology, and acts through its end effector."@en .

g04:gripper01
    a cap:EndEffector ;
    rdfs:label "parallel gripper 01"@en ;
    rdfs:comment
        "The parallel-jaw gripper attached to the robot agent, used for grasping and manipulating physical objects."@en .

# =============================================================================
# Affordance Modeling Policy (PDF §6 — Affordance layer)
# =============================================================================
# This ontology does not create named affordance individuals for each object.
# Instead, object affordances are inferred from class-level existential
# restrictions such as:
#   cap:Cup rdfs:subClassOf [
#       owl:onProperty cap:hasAffordance ;
#       owl:someValuesFrom cap:GraspingAffordance
#   ] .
# The custom reasoner materializes these restrictions as anonymous affordance
# blank nodes in the inferred graph, keeping the asserted group ontology compact.

# =============================================================================
# Environment Instances — Baseline Objects (PDF §10)
# =============================================================================
# All three predefined tasks are covered regardless of selected task.

# --- Cup Stacking Task Objects ---

g04:blueCup01
    a cap:Cup ;
    rdfs:label "blue cup 01"@en ;
    rdfs:comment
        "The blue cup instance defined by Group 04 for the baseline cup-stacking task."@en ;
    cap:hasColor "blue" ;
    cap:hasObjectLabel "blue_cup" ;
    cap:hasTaskRole cap:TargetObject ;
    cap:hasPoseFrame "world/object_blue_cup" ;
    cap:canBeManipulatedBy g04:gripper01 .

g04:pinkCup01
    a cap:Cup ;
    rdfs:label "pink cup 01"@en ;
    rdfs:comment
        "The pink cup instance defined by Group 04 for the baseline cup-stacking task."@en ;
    cap:hasColor "pink" ;
    cap:hasObjectLabel "pink_cup" ;
    cap:hasTaskRole cap:TargetObject ;
    cap:hasPoseFrame "world/object_pink_cup" ;
    cap:canBeManipulatedBy g04:gripper01 .

# --- Cutlery Arrangement Task Objects ---

g04:knife01
    a cap:Knife ;
    rdfs:label "knife 01"@en ;
    rdfs:comment
        "The knife instance defined by Group 04 for the baseline cutlery-arrangement task."@en ;
    cap:hasColor "silver" ;
    cap:hasObjectLabel "knife" ;
    cap:hasTaskRole cap:TargetObject ;
    cap:hasPoseFrame "world/object_knife" ;
    cap:canBeManipulatedBy g04:gripper01 .

g04:fork01
    a cap:Fork ;
    rdfs:label "fork 01"@en ;
    rdfs:comment
        "The fork instance defined by Group 04 for the baseline cutlery-arrangement task."@en ;
    cap:hasColor "silver" ;
    cap:hasObjectLabel "fork" ;
    cap:hasTaskRole cap:TargetObject ;
    cap:hasPoseFrame "world/object_fork" ;
    cap:canBeManipulatedBy g04:gripper01 .

g04:plate01
    a cap:Plate ;
    rdfs:label "plate 01"@en ;
    rdfs:comment
        "The plate instance defined by Group 04 for the baseline cutlery-arrangement task. Serves as a reference object for placing cutlery; not directly grasped."@en ;
    cap:hasColor "white" ;
    cap:hasObjectLabel "plate" ;
    cap:hasTaskRole cap:ReferenceObject ;
    cap:hasPoseFrame "world/object_plate" .

# --- Toy Block Collection Task Objects ---

g04:block01
    a cap:ToyBlock ;
    rdfs:label "toy block 01"@en ;
    rdfs:comment
        "The toy block instance defined by Group 04 for the baseline toy-block-collection task."@en ;
    cap:hasColor "red" ;
    cap:hasObjectLabel "toy_block" ;
    cap:hasTaskRole cap:CollectableObject ;
    cap:hasPoseFrame "world/object_block" ;
    cap:canBeManipulatedBy g04:gripper01 .

g04:basket01
    a cap:Basket ;
    rdfs:label "basket 01"@en ;
    rdfs:comment
        "The basket instance defined by Group 04 for the baseline toy-block-collection task. Serves as the container target for collecting toy blocks; not directly grasped."@en ;
    cap:hasColor "brown" ;
    cap:hasObjectLabel "basket" ;
    cap:hasTaskRole cap:ContainerTarget ;
    cap:hasPoseFrame "world/object_basket" .

# =============================================================================
# Task Instances (PDF §6 — enriches semantic richness)
# =============================================================================

g04:cupStackingTask
    a cap:ManipulationTask ;
    rdfs:label "cup stacking task"@en ;
    rdfs:comment
        "A manipulation task in which the robot stacks cups by grasping and placing them."@en ;
    cap:hasTargetObject g04:blueCup01 ;
    cap:hasTargetObject g04:pinkCup01 .

g04:cutleryArrangementTask
    a cap:ManipulationTask ;
    rdfs:label "cutlery arrangement task"@en ;
    rdfs:comment
        "A manipulation task in which the robot arranges cutlery relative to a plate."@en ;
    cap:hasTargetObject g04:knife01 ;
    cap:hasTargetObject g04:fork01 ;
    cap:hasReferenceObject g04:plate01 .

g04:blockCollectionTask
    a cap:ManipulationTask ;
    rdfs:label "toy block collection task"@en ;
    rdfs:comment
        "A manipulation task in which the robot collects toy blocks into a basket."@en ;
    cap:hasTargetObject g04:block01 ;
    cap:hasReferenceObject g04:basket01 .

# =============================================================================
# ADVANCED TASK — Shell Game / Ball-under-Cup (PDF §4, §19)
# =============================================================================
# Task (kitchen scene): several visually identical cups stand in the scene; a
# small ball is hidden under one cup; the cups are shuffled; the robot must grasp
# the cup that hides the ball. The ontology models the *post-shuffle grounded
# state* the robot perceives. The cups are indistinguishable by appearance (same
# class, colour, and object label) and are separated only by identity / pose
# frame, so which cup is the retrieval target cannot be read off appearance — it
# is INFERRED (not asserted) via the g04:BallConcealingCup equivalent-class axiom.
# This demonstrates the spec's core distinction that "graspable" (all cups)
# differs from "task target" (the one cup concealing the ball).
# Note: the table/counter belongs to the kitchen scene background and is NOT
# modelled as a task object.

# --- New object class: Ball (the hidden item; NOT graspable in this model) ---

g04:Ball
    a owl:Class ;
    rdfs:subClassOf cap:PhysicalObject ;
    rdfs:label "ball"@en ;
    rdfs:comment
        "A small ball used in the shell-game task. It is the item hidden under a cup. In Group 04's model the ball is not a direct grasp target (no grasping affordance); the robot retrieves it indirectly by grasping the concealing cup."@en .

# --- New object property: conceals (perception-grounded fact) ---

g04:conceals
    a owl:ObjectProperty ;
    rdfs:domain cap:Cup ;
    rdfs:range g04:Ball ;
    rdfs:label "conceals"@en ;
    rdfs:comment
        "Relates a cup to a ball that is hidden under (concealed by) that cup in the post-shuffle state. This is a perception/tracking-grounded fact asserted by the robot, from which the retrieval target is inferred."@en .

g04:concealedBy
    a owl:ObjectProperty ;
    owl:inverseOf g04:conceals ;
    rdfs:domain g04:Ball ;
    rdfs:range cap:Cup ;
    rdfs:label "concealed by"@en ;
    rdfs:comment
        "Inverse of g04:conceals: relates a ball to the cup that hides it."@en .

# --- New datatype property: isOpaque (perception-grounded physical property) ---

g04:isOpaque
    a owl:DatatypeProperty ;
    rdfs:domain cap:PhysicalObject ;
    rdfs:range xsd:boolean ;
    rdfs:label "is opaque"@en ;
    rdfs:comment
        "Records whether a physical object is visually opaque (cannot be seen through). Orthogonal to cap:hasColor (which records colour only). In the shell-game task opacity is the perceptual property that makes concealment possible: because the cups are opaque, the robot cannot see which one hides the ball and must infer the retrieval target by reasoning rather than direct observation."@en .

# --- New affordance: ConcealmentAffordance ---

g04:ConcealmentAffordance
    a owl:Class ;
    rdfs:subClassOf cap:ContainmentAffordance ;
    rdfs:label "concealment affordance"@en ;
    rdfs:comment
        "An affordance by which an inverted, opaque cup can hide (conceal) a small object placed under it. A specialization of cap:ContainmentAffordance scoped to the shell-game occlusion semantics."@en .

# --- New task roles ---

g04:CandidateContainer
    a owl:Class ;
    rdfs:subClassOf cap:TaskRole ;
    rdfs:label "candidate container"@en ;
    rdfs:comment
        "The role of a cup that may conceal the target ball before reasoning identifies the actual concealing cup. Asserted on every shell-game cup so that no single cup is pre-labelled as the answer."@en .

g04:HiddenItem
    a owl:Class ;
    rdfs:subClassOf cap:TaskRole ;
    rdfs:label "hidden item"@en ;
    rdfs:comment
        "The role of the object that is concealed under a cup and must be located by the robot through the concealing cup."@en .

# --- Inferred target class: BallConcealingCup (PDF §11 reasoning pattern) ---
# DL: g04:BallConcealingCup ≡ cap:Cup ⊓ ∃ g04:conceals . g04:Ball

g04:BallConcealingCup
    a owl:Class ;
    rdfs:label "ball-concealing cup"@en ;
    rdfs:comment
        "A cup inferred to conceal the target ball, and therefore the robot's retrieval (grasp) target in the shell-game task. Defined as the intersection of cap:Cup and the existential restriction that the cup conceals at least one g04:Ball. Membership is derived by the reasoner from g04:conceals assertions, not asserted directly."@en ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            cap:Cup
            [ a owl:Restriction ;
              owl:onProperty g04:conceals ;
              owl:someValuesFrom g04:Ball ]
        )
    ] .

# --- Shell-game cup instances (identical opaque cups: same class, colour, and
#     object label; distinguished only by identity and pose frame) ---

g04:shellCup01
    a cap:Cup ;
    rdfs:label "shell cup 01"@en ;
    rdfs:comment
        "Shell-game cup 01: one of several identical opaque cups that may conceal the ball. Empty in the current post-shuffle state."@en ;
    cap:hasColor "pink" ;
    g04:isOpaque true ;
    cap:hasObjectLabel "shell_cup" ;
    cap:hasTaskRole g04:CandidateContainer ;
    cap:hasPoseFrame "world/object_cup01" ;
    cap:hasAffordance [ a g04:ConcealmentAffordance ] ;
    cap:canBeManipulatedBy g04:gripper01 .

g04:shellCup02
    a cap:Cup ;
    rdfs:label "shell cup 02"@en ;
    rdfs:comment
        "Shell-game cup 02: identical to the other cups, but conceals the ball in the current post-shuffle state. The reasoner infers it as g04:BallConcealingCup (the retrieval target)."@en ;
    cap:hasColor "pink" ;
    g04:isOpaque true ;
    cap:hasObjectLabel "shell_cup" ;
    cap:hasTaskRole g04:CandidateContainer ;
    cap:hasPoseFrame "world/object_cup02" ;
    cap:hasAffordance [ a g04:ConcealmentAffordance ] ;
    cap:canBeManipulatedBy g04:gripper01 ;
    g04:conceals g04:ball01 .

g04:shellCup03
    a cap:Cup ;
    rdfs:label "shell cup 03"@en ;
    rdfs:comment
        "Shell-game cup 03: one of several identical opaque cups that may conceal the ball. Empty in the current post-shuffle state."@en ;
    cap:hasColor "pink" ;
    g04:isOpaque true ;
    cap:hasObjectLabel "shell_cup" ;
    cap:hasTaskRole g04:CandidateContainer ;
    cap:hasPoseFrame "world/object_cup03" ;
    cap:hasAffordance [ a g04:ConcealmentAffordance ] ;
    cap:canBeManipulatedBy g04:gripper01 .

# --- Ball instance (the hidden item) ---

g04:ball01
    a g04:Ball ;
    rdfs:label "ball 01"@en ;
    rdfs:comment
        "The small ball hidden under one of the shell-game cups in the current post-shuffle state."@en ;
    cap:hasColor "white" ;
    cap:hasObjectLabel "ball" ;
    cap:hasTaskRole g04:HiddenItem ;
    cap:hasPoseFrame "world/object_ball" .

# --- Shell-game task instance ---

g04:shellGameTask
    a cap:ManipulationTask ;
    rdfs:label "shell game task"@en ;
    rdfs:comment
        "A manipulation task in which a ball is hidden under one of several shuffled, identical cups and the robot must grasp the cup that conceals the ball. The retrieval target is the inferred g04:BallConcealingCup."@en ;
    cap:hasTargetObject g04:shellCup01 ;
    cap:hasTargetObject g04:shellCup02 ;
    cap:hasTargetObject g04:shellCup03 ;
    cap:hasReferenceObject g04:ball01 .
